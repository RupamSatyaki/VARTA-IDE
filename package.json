{
  "name": "varta",
  "version": "0.1.0",
  "description": "Varta — A desktop code editor built with Electron + React + TypeScript",
  "main": "./out/main/index.js",
  "author": "Varta Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w node-pty",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --project tsconfig.node.json --noEmit",
    "typecheck:web": "tsc --project tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.20.9",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@monaco-editor/react": "4.6.0",
    "@parcel/watcher": "^2.5.6",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "axios": "1.16.0",
    "electron-store": "8.2.0",
    "framer-motion": "^12.38.0",
    "ignore": "7.0.5",
    "immer": "^10.1.1",
    "monaco-editor": "0.47.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "seti-file-icons": "0.0.8",
    "simple-git": "3.25.0",
    "xterm": "5.3.0",
    "xterm-addon-fit": "0.8.0",
    "xterm-addon-search": "0.13.0",
    "xterm-addon-web-links": "0.9.0",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "2.0.0",
    "@electron-toolkit/eslint-config-ts": "2.0.0",
    "@electron-toolkit/tsconfig": "1.0.1",
    "@electron-toolkit/utils": "3.0.0",
    "@types/node": "20.14.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.13.0",
    "@typescript-eslint/parser": "7.13.0",
    "@vitejs/plugin-react": "4.3.1",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "10.4.19",
    "electron": "31.1.0",
    "electron-builder": "24.13.3",
    "electron-rebuild": "3.2.9",
    "electron-vite": "2.3.0",
    "eslint": "8.57.0",
    "eslint-plugin-react": "7.34.3",
    "eslint-plugin-react-hooks": "4.6.2",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.2",
    "vite": "5.3.1",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0"
  }
}
